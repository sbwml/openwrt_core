Package: kmod-keys-encrypted
Version: 6.12-rc3-r1
Depends: kernel (=6.12-rc3~448ec6e18f28386e8034001b571f7bff-r1), kmod-crypto-cbc, kmod-crypto-hmac, kmod-crypto-rng, kmod-crypto-sha256, kmod-keys-trusted
